<?xml version="1.0" encoding="utf-8"?>
<!-- The Ashlar Protocol - adaptive icon foreground: the ashlar caught mid-shaping
     (left face raw/unhewn, top + right dressed and gold-trued). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Cast shadow -->
    <path
        android:fillColor="#000000"
        android:fillAlpha="0.28"
        android:pathData="M30,83 a24,5.4 0 1,0 48,0 a24,5.4 0 1,0 -48,0 Z" />

    <!-- Right face (dressed) -->
    <path android:pathData="M54,52 L78,38 L78,66 L54,80 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="54" android:startY="52" android:endX="78" android:endY="80">
                <item android:offset="0.0" android:color="#FFAB9670" />
                <item android:offset="1.0" android:color="#FF8F7A55" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Left face (raw / unhewn base) -->
    <path android:pathData="M30,38 L54,52 L54,80 L30,66 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="30" android:startY="38" android:endX="54" android:endY="80">
                <item android:offset="0.0" android:color="#FFB7A57E" />
                <item android:offset="1.0" android:color="#FF94805A" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Rough tooling, clipped to the raw face -->
    <group>
        <clip-path android:pathData="M30,38 L54,52 L54,80 L30,66 Z" />

        <!-- soft matte darkening toward the bottom -->
        <path android:pathData="M30,38 L54,52 L54,80 L30,66 Z">
            <aapt:attr name="android:fillColor">
                <gradient android:type="linear"
                    android:startX="42" android:startY="44" android:endX="42" android:endY="82">
                    <item android:offset="0.0" android:color="#002A2113" />
                    <item android:offset="1.0" android:color="#332A2113" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- light relief pass -->
        <path
            android:strokeColor="#38F5EDD6" android:strokeWidth="0.35" android:strokeLineCap="round"
            android:pathData="M34.3,46.9 L39,49.9 M41.2,47.9 L45,51.4 M33.3,51.9 L40,55.9 M44.3,53.9 L49,57.4 M36.3,56.9 L39,60.9 M40.3,57.9 L47,61.4 M34.3,60.9 L41,64.4 M43.3,61.9 L48,64.9 M37.3,64.9 L44,68.4 M45.3,66.9 L50,69.9 M39.3,68.9 L45,72.4" />

        <!-- dark chisel cuts (irregular angle + length) -->
        <path
            android:strokeColor="#80564629" android:strokeWidth="0.55" android:strokeLineCap="round"
            android:pathData="M34,46.5 L39,49.5 M41,47.5 L45,51 M33,51.5 L40,55.5 M44,53.5 L49,57 M36,56.5 L39,60.5 M40,57.5 L47,61 M34,60.5 L41,64 M43,61.5 L48,64.5 M37,64.5 L44,68 M45,66.5 L50,69.5 M39,68.5 L45,72 M35,59 L38,56 M42,67 L45,64 M37,70 L40,67.5" />

        <!-- shallow pits -->
        <path
            android:strokeColor="#6B4A3D27" android:strokeWidth="0.8" android:strokeLineCap="round"
            android:pathData="M38.4,53.2 l0.01,0 M46,58.6 l0.01,0 M41.2,62.4 l0.01,0 M35.6,65.8 l0.01,0 M48.3,63.1 l0.01,0" />
    </group>

    <!-- Top face (dressed, light) -->
    <path android:pathData="M54,24 L78,38 L54,52 L30,38 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="30" android:startY="24" android:endX="78" android:endY="52">
                <item android:offset="0.0" android:color="#FFF6EFDD" />
                <item android:offset="1.0" android:color="#FFE7DAC0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Dressed-edge highlight along the crown -->
    <path android:pathData="M30,38 L54,24 L78,38"
        android:strokeColor="#59FFF7E6" android:strokeWidth="0.5"
        android:strokeLineJoin="round" />

    <!-- Gold "square and true" seams — only the DRESSED, trued edges are gilded -->
    <path android:pathData="M54,52 L78,38"
        android:strokeColor="#E6D9A94E" android:strokeWidth="0.9" />
    <path android:pathData="M54,52 L54,80"
        android:strokeColor="#B3D9A94E" android:strokeWidth="0.7" />
    <!-- the raw-side top ridge stays a dull stone edge, not gilded -->
    <path android:pathData="M30,38 L54,52"
        android:strokeColor="#806E5C3C" android:strokeWidth="0.6" />
</vector>
